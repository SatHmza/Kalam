# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get this from neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/kalam?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-secret"
# In production: https://kalam.vercel.app  |  In dev: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Blob (file uploads) ───────────────────────────────────────────────
# Added automatically by Vercel when you connect Blob storage in the dashboard
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
